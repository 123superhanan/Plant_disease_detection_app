{
  "expo": {
    "name": "ArgoVision",
    "slug": "argo-vision",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "argovision",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.argovision.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow AgroVision to access your camera to scan for diseases.",
        "NSPhotoLibraryUsageDescription": "Allow AgroVision to access your photos to analyze plant health."
      }
    },
    "android": {
      "package": "com.argovision.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AgroVision to access your photos to analyze plant health.",
          "cameraPermission": "Allow AgroVision to access your camera to scan for diseases."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
